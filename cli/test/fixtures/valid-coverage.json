{
  "meta": {
    "name": "valid-coverage-test",
    "goal": "Test that a fully compliant spec passes all coverage checks",
    "schema_version": "v6"
  },
  "decisions": [
    {
      "id": "D1",
      "title": "Use JSON schema validation",
      "rationale": "Provides structured validation"
    }
  ],
  "requirements": [
    {
      "id": "R1",
      "behavior": "CLI validates coverage",
      "priority": 1,
      "source": {
        "type": "decision",
        "ref": "D1"
      },
      "sub": [
        {
          "id": "R1.1",
          "behavior": "Exits 0 when spec coverage is run on a valid spec",
          "verify": {
            "type": "command",
            "run": "node dist/cli.js spec coverage test/fixtures/valid-coverage.json",
            "expect": { "exit_code": 0 }
          }
        },
        {
          "id": "R1.2",
          "behavior": "Exits 1 when spec coverage is run on a spec with a gap",
          "verify": {
            "type": "command",
            "run": "node dist/cli.js spec coverage test/fixtures/broken-source-ref.json",
            "expect": { "exit_code": 1 }
          }
        },
        {
          "id": "R1.3",
          "behavior": "Exits 1 when spec coverage is run on a spec with uncovered decision",
          "verify": {
            "type": "command",
            "run": "node dist/cli.js spec coverage test/fixtures/uncovered-decision.json",
            "expect": { "exit_code": 1 }
          }
        }
      ]
    }
  ],
  "tasks": [
    {
      "id": "T1",
      "action": "Implement coverage command",
      "type": "work",
      "status": "pending",
      "fulfills": ["R1"],
      "acceptance_criteria": {
        "checks": []
      }
    }
  ]
}
