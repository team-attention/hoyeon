{
  "meta": {
    "name": "no-decisions-test",
    "goal": "Test that a spec with no decisions trivially passes decision coverage",
    "schema_version": "v6"
  },
  "decisions": [],
  "requirements": [
    {
      "id": "R1",
      "behavior": "CLI handles empty decisions gracefully",
      "priority": 1,
      "sub": [
        {
          "id": "R1.1",
          "behavior": "Exits 0 when spec coverage is run on a spec with no decisions",
          "verify": {
            "type": "command",
            "run": "node dist/cli.js spec coverage test/fixtures/no-decisions.json",
            "expect": { "exit_code": 0 }
          }
        },
        {
          "id": "R1.2",
          "behavior": "Exits 0 trivially when spec coverage is run on a spec with no decisions but invalid coverage",
          "verify": {
            "type": "command",
            "run": "node dist/cli.js spec coverage test/fixtures/no-decisions.json",
            "expect": { "exit_code": 0 }
          }
        },
        {
          "id": "R1.3",
          "behavior": "Exits 0 when spec coverage --layer decisions is run on a spec with no decisions",
          "verify": {
            "type": "command",
            "run": "node dist/cli.js spec coverage test/fixtures/no-decisions.json --layer decisions",
            "expect": { "exit_code": 0 }
          }
        }
      ]
    }
  ],
  "tasks": [
    {
      "id": "T1",
      "action": "Implement graceful no-decisions handling",
      "type": "work",
      "status": "pending",
      "fulfills": ["R1"],
      "acceptance_criteria": {
        "checks": []
      }
    }
  ]
}
