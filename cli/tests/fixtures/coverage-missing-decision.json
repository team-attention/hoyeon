  "requirements": [
    {
      "id": "R1",
      "behavior": "CLI initializes a spec from the project goal",
      "priority": 1,
      "source": { "type": "goal" },
      "sub": [
        {
          "id": "R1.1",
          "behavior": "A valid spec.json is created when spec init is run with a goal in a new project directory",
          "verify": {
            "type": "command",
            "run": "hoyeon-cli spec init test-proj --goal 'Test' /tmp/test/spec.json",
            "expect": { "exit_code": 0 }
          }
        },
        {
          "id": "R1.2",
          "behavior": "An error is returned and no overwrite occurs when spec init is run again in a directory where spec.json already exists",
          "verify": {
            "type": "command",
            "run": "hoyeon-cli spec init test-proj --goal 'Test' /tmp/existing/spec.json",
            "expect": { "exit_code": 1 }
          }
        },
        {
          "id": "R1.3",
          "behavior": "Validation passes with exit code 0 when spec validate is run on a valid spec.json",
          "verify": {
            "type": "command",
            "run": "hoyeon-cli spec validate /tmp/test/spec.json",
            "expect": { "exit_code": 0 }
          }
        }
      ]
    },
    {
      "id": "R2",
      "behavior": "CLI uses a decision-driven feature",
      "priority": 2,
      "source": { "type": "decision", "ref": "D3" },
      "sub": [
        {
          "id": "R2.1",
          "behavior": "CLI executes successfully using Node.js when the CLI binary is invoked and node is available on the system",
          "verify": {
            "type": "command",
            "run": "node --version",
            "expect": { "exit_code": 0 }
          }
        },
        {
          "id": "R2.2",
          "behavior": "A version error is printed when CLI is invoked with an incompatible Node.js version",
          "verify": {
            "type": "assertion",
            "checks": ["Error message references Node.js version requirement"]
          }
        },
        {
          "id": "R2.3",
          "behavior": "Help text is printed when hoyeon-cli is called without arguments after being installed globally",
          "verify": {
            "type": "command",
            "run": "hoyeon-cli --help",
            "expect": { "exit_code": 0 }
          }
        }
      ]
    }
  ],
